rules_version = '2';

// 토큰(추측불가 URL) 기반 접근 모델.
// - envelopeId 자체가 비밀키 역할: 링크를 아는 사람만 접근.
// - 서명 영역/ PDF는 생성 후 불변. 서명자는 signatures 서브컬렉션에만 기록.
// 내부 결재/확인용 수준이며, 강한 본인인증이 필요하면 Firebase Auth로 격상해야 한다.
service cloud.firestore {
  match /databases/{database}/documents {

    match /envelopes/{envelopeId} {
      // 불가추측 envelopeId(링크)를 아는 사람만 '단건' 조회 가능.
      allow get: if true;
      // 컬렉션 전체 열거(덤프) 차단 — 다른 사람 문서를 훑어볼 수 없음.
      allow list: if false;
      // 봉투 생성은 로그인한 관리자만.
      allow create: if request.auth != null;
      // 생성 후 메타/서명영역은 불변(수정 금지).
      allow update: if false;
      // 프로젝트 전체 취소·삭제도 로그인한 관리자만.
      allow delete: if request.auth != null;

      // PDF 원본 청크: 읽기는 공개(서명자), 쓰기·삭제는 관리자만.
      match /pdfChunks/{chunkId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if false;
        allow delete: if request.auth != null;
      }

      // 서명 결과: 서명자(비로그인)가 채운다. fieldId 문서 1개 = 서명영역 1개.
      match /signatures/{fieldId} {
        allow read: if true;
        // 이미지 데이터와 서명자 토큰이 있어야 기록 가능(서명자는 로그인 없음).
        allow create, update: if request.resource.data.keys().hasAll(['image', 'signerToken'])
          && request.resource.data.image is string
          && request.resource.data.image.size() < 900000;
        // 서명 삭제(프로젝트 삭제 시)는 관리자만.
        allow delete: if request.auth != null;
      }
    }
  }
}
